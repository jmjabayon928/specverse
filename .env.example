############################################
# Specverse example environment file
# DO NOT PUT REAL SECRETS HERE
############################################

# Backend (Express)
NODE_ENV=development
SPECVERSE_ENV=local

# Backend internal origin for Next proxy (local dev)
BACKEND_INTERNAL_ORIGIN=http://localhost:4000

# Trust proxy (optional override for local; 1 to enable)
BACKEND_TRUST_PROXY=0

# Auth / JWT (placeholders only)
JWT_SECRET=CHANGEME
JWT_EXPIRES_IN=60m

# Database connection (placeholders only)
DB_HOST=CHANGEME
DB_PORT=CHANGEME
DB_USER=CHANGEME
DB_PASSWORD=CHANGEME
DB_NAME=CHANGEME

